# Copy this file to .env and fill in your values
# All variables without defaults in docker-compose.yml are REQUIRED

# ── PostgreSQL ──
POSTGRES_DB=ares
POSTGRES_USER=ares_user
POSTGRES_PASSWORD=<generate-a-strong-password>

# ── Flask ──
FLASK_ENV=development
SECRET_KEY=<generate-a-random-secret-key>

# ── Google OAuth 2.0 ──
# Get these from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/api/login/google/callback
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ── Facebook OAuth ──
# Get these from https://developers.facebook.com/apps
# Valid OAuth redirect URI: http://localhost:8080/api/login/facebook/callback
FACEBOOK_CLIENT_ID=<your-facebook-app-id>
FACEBOOK_CLIENT_SECRET=<your-facebook-app-secret>

# ── Gemini (optional, falls back to rule-based fraud analysis) ──
GEMINI_API_KEY=
