# Copy this file to .env and fill in your values
# All variables without defaults in docker-compose.yml are REQUIRED

# ── PostgreSQL ──
POSTGRES_DB=ares
POSTGRES_USER=ares_user
POSTGRES_PASSWORD=<generate-a-strong-password>

# ── Flask ──
FLASK_ENV=development
SECRET_KEY=<generate-a-random-secret-key>

# ── Google OAuth 2.0 ──
# Get these from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/api/login/google/callback
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ── Google reCAPTCHA v2 Checkbox (optional, recommended) ──
# Register a site in Google reCAPTCHA admin console and add localhost
# for local testing. If both values are set, challenged logins require challenge.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Azure OpenAI (for LLM fraud analysis) ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Gemini (optional fallback) ──
GEMINI_API_KEY=
